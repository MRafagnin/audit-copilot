# Copy to .env (gitignored) and fill in. HTTP_USER_AGENT is the only required edit.

# --- LLM (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b-instruct
LLM_TIMEOUT_SECONDS=120

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store ---
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=audit_corpus

# --- RAG retrieval ---
RAG_TOP_K=8
RAG_MIN_SCORE=0.35

# --- HTTP (polite scraping — identify the caller when fetching AUASB / ASX PDFs) ---
# Format: "Name email@domain"
HTTP_USER_AGENT=Your Name your.email@example.com

# --- Corpus ---
# ASX ticker of the company whose annual report grounds the RAG corpus.
DEMO_TICKER=WOW

# --- Anomaly detection ---
ANOMALY_SEED=42
GL_ROW_COUNT=50000

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
