{
  "$schema": "https://aka.ms/vscode-hooks-schema",
  "description": "Command Guard enforcement + context injection. PreToolUse classifies every terminal command ([READ-ONLY]|[MUTATION]|[DESTRUCTIVE]|[SYSTEM]); SessionStart and UserPromptSubmit inject the classification legend so the agent labels commands in its reasoning.",
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "matcher": "runInTerminal|run_in_terminal",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\.github\\hooks\\classify-command.ps1\"",
        "linux":   "pwsh -NoProfile -File \"${workspaceFolder}/.github/hooks/classify-command.ps1\"",
        "osx":     "pwsh -NoProfile -File \"${workspaceFolder}/.github/hooks/classify-command.ps1\"",
        "timeout": 5
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\.github\\hooks\\inject-guards-legend.ps1\"",
        "linux":   "pwsh -NoProfile -File \"${workspaceFolder}/.github/hooks/inject-guards-legend.ps1\"",
        "osx":     "pwsh -NoProfile -File \"${workspaceFolder}/.github/hooks/inject-guards-legend.ps1\"",
        "timeout": 5
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\.github\\hooks\\inject-guards-legend.ps1\"",
        "linux":   "pwsh -NoProfile -File \"${workspaceFolder}/.github/hooks/inject-guards-legend.ps1\"",
        "osx":     "pwsh -NoProfile -File \"${workspaceFolder}/.github/hooks/inject-guards-legend.ps1\"",
        "timeout": 5
      }
    ]
  }
}
